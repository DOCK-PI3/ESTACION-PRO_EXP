<?xml version="1.0" encoding="UTF-8"?>
<!--
    Theme capabilities for arcadepower-es-de
-->

<themeCapabilities>
    <themeName>ArcadePower</themeName>

    <language>es_ES</language>
    <language>en_US</language>

    <aspectRatio>16:9</aspectRatio>
    <aspectRatio>16:10</aspectRatio>
    <aspectRatio>4:3</aspectRatio>

    <fontSize>medium</fontSize>

    <colorScheme name="default">
        <label language="es_ES">Por defecto</label>
        <label language="en_US">Default</label>
    </colorScheme>

    <!-- Variantes de vista de gamelist -->
    <variant name="basic" selectable="true">
        <label language="es_ES">Básico</label>
        <label language="en_US">Basic</label>
        <gamelistViewStyle>true</gamelistViewStyle>
    </variant>
    <variant name="detailed" selectable="true">
        <label language="es_ES">Detallado</label>
        <label language="en_US">Detailed</label>
        <gamelistViewStyle>true</gamelistViewStyle>
    </variant>
    <variant name="grid" selectable="true">
        <label language="es_ES">Cuadrícula</label>
        <label language="en_US">Grid</label>
        <gamelistViewStyle>true</gamelistViewStyle>
    </variant>
    <variant name="carousel" selectable="true">
        <label language="es_ES">Carrusel</label>
        <label language="en_US">Carousel</label>
        <gamelistViewStyle>true</gamelistViewStyle>
    </variant>
    <variant name="icons" selectable="true">
        <label language="es_ES">Iconos</label>
        <label language="en_US">Icons</label>
        <gamelistViewStyle>true</gamelistViewStyle>
    </variant>

    <!-- Subsets para systemview -->
    <subset name="systemview">
        <option name="darkened">
            <label language="es_ES">Oscurecido</label>
            <label language="en_US">Darkened</label>
        </option>
        <option name="horizontal">
            <label language="es_ES">Horizontal</label>
            <label language="en_US">Horizontal</label>
        </option>
        <option name="vertical">
            <label language="es_ES">Vertical</label>
            <label language="en_US">Vertical</label>
        </option>
        <option name="wheel">
            <label language="es_ES">Rueda</label>
            <label language="en_US">Wheel</label>
        </option>
        <option name="simple">
            <label language="es_ES">Simple</label>
            <label language="en_US">Simple</label>
        </option>
    </subset>
</themeCapabilities>
